{
  "tests": [
    {
      "name": "Get auth URL via POST",
      "method": "POST",
      "path": "/",
      "body": {"action": "get_auth_url", "redirect_uri": "https://example.com/callback"},
      "expectedStatus": 200,
      "expectedBody": {"auth_url": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify invalid token",
      "method": "POST",
      "path": "/",
      "body": {"action": "verify", "token": "invalid.token.here"},
      "expectedStatus": 401,
      "expectedBody": {"error": "invalid_token"},
      "bodyMatcher": "partial"
    },
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    }
  ]
}
